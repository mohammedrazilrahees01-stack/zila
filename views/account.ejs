<%- include('partials/header') %>

<section class="bg-[#fdf6ec] min-h-screen pt-32 pb-24 px-6 md:px-16 font-['Poppins']">
  <div class="container mx-auto max-w-5xl">

    <!-- Page Header -->
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between mb-12 pb-8 border-b border-gray-200">
      <div class="flex items-center gap-5">
        <div class="w-16 h-16 bg-[#f8bc45] rounded-2xl flex items-center justify-center text-2xl font-black text-black shadow-lg">
          <%= (userData.name || userData.email || 'Z').charAt(0).toUpperCase() %>
        </div>
        <div>
          <h1 class="text-3xl font-black text-gray-900">My Account</h1>
          <p class="text-gray-500 font-medium"><%= userData.email %></p>
          <p class="text-xs text-gray-400 mt-1">Member since <%= userData.created_at ? new Date(userData.created_at).toLocaleDateString('en-IN', {year:'numeric',month:'long'}) : 'N/A' %></p>
        </div>
      </div>
      <div class="flex gap-3 mt-4 md:mt-0">
        <a href="/orders" class="flex items-center gap-2 bg-white border border-gray-200 px-4 py-2.5 rounded-xl font-bold text-sm hover:border-black transition">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
          My Orders
        </a>
        <a href="/wishlist" class="flex items-center gap-2 bg-white border border-gray-200 px-4 py-2.5 rounded-xl font-bold text-sm hover:border-black transition">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
          Wishlist
        </a>
        <a href="/logout" class="flex items-center gap-2 bg-red-50 text-red-500 border border-red-100 px-4 py-2.5 rounded-xl font-bold text-sm hover:bg-red-100 transition">Logout</a>
      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-8">

      <!-- Profile Form -->
      <div class="bg-white rounded-3xl p-8 shadow-sm border border-gray-100">
        <h2 class="text-xl font-black mb-6 flex items-center gap-2">
          <svg class="w-5 h-5 text-[#e09e2b]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          Profile Details
        </h2>
        <form action="/account/update" method="POST" class="space-y-4">
          <div>
            <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Full Name</label>
            <input type="text" name="name" value="<%= userData.name || '' %>" placeholder="Your full name"
              class="w-full border border-gray-200 p-4 rounded-xl bg-gray-50 outline-none focus:border-black focus:bg-white transition font-medium text-sm">
          </div>
          <div>
            <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Email</label>
            <input type="email" value="<%= userData.email %>" disabled
              class="w-full border border-gray-100 p-4 rounded-xl bg-gray-100 text-gray-400 font-medium text-sm cursor-not-allowed">
          </div>
          <div>
            <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Phone</label>
            <input type="tel" name="phone" value="<%= userData.phone || '' %>" placeholder="+91 98765 43210"
              class="w-full border border-gray-200 p-4 rounded-xl bg-gray-50 outline-none focus:border-black focus:bg-white transition font-medium text-sm">
          </div>
          <div>
            <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Address</label>
            <textarea name="address" rows="2" placeholder="House No., Street, Area"
              class="w-full border border-gray-200 p-4 rounded-xl bg-gray-50 outline-none focus:border-black focus:bg-white transition font-medium text-sm resize-none"><%= userData.address || '' %></textarea>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">City</label>
              <input type="text" name="city" value="<%= userData.city || '' %>" placeholder="City"
                class="w-full border border-gray-200 p-4 rounded-xl bg-gray-50 outline-none focus:border-black focus:bg-white transition font-medium text-sm">
            </div>
            <div>
              <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Pincode</label>
              <input type="text" name="pincode" value="<%= userData.pincode || '' %>" placeholder="000000"
                class="w-full border border-gray-200 p-4 rounded-xl bg-gray-50 outline-none focus:border-black focus:bg-white transition font-medium text-sm">
            </div>
          </div>
          <button type="submit" class="w-full relative overflow-hidden glass-btn btn-shine text-white font-bold uppercase tracking-widest py-4 rounded-xl text-sm shadow-lg">
            Save Changes
          </button>
        </form>
      </div>

      <!-- Right Column -->
      <div class="space-y-6">
        <!-- Change Password -->
        <div class="bg-white rounded-3xl p-8 shadow-sm border border-gray-100">
          <h2 class="text-xl font-black mb-6 flex items-center gap-2">
            <svg class="w-5 h-5 text-[#e09e2b]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
            Change Password
          </h2>
          <% if(locals.error === 'wrong_password') { %>
            <div class="bg-red-50 border border-red-100 text-red-600 text-sm font-bold p-3 rounded-xl mb-4">❌ Current password is incorrect.</div>
          <% } %>
          <form action="/account/change-password" method="POST" class="space-y-4">
            <div>
              <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Current Password</label>
              <input type="password" name="current_password" placeholder="••••••••"
                class="w-full border border-gray-200 p-4 rounded-xl bg-gray-50 outline-none focus:border-black focus:bg-white transition font-medium text-sm" required>
            </div>
            <div>
              <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">New Password</label>
              <input type="password" name="new_password" placeholder="••••••••" minlength="6"
                class="w-full border border-gray-200 p-4 rounded-xl bg-gray-50 outline-none focus:border-black focus:bg-white transition font-medium text-sm" required>
            </div>
            <button type="submit" class="w-full bg-gray-900 text-white font-bold uppercase tracking-widest py-3.5 rounded-xl text-sm hover:bg-[#e09e2b] transition-all duration-300">
              Update Password
            </button>
          </form>
        </div>

        <!-- Recent Orders Quick View -->
        <div class="bg-white rounded-3xl p-8 shadow-sm border border-gray-100">
          <div class="flex justify-between items-center mb-6">
            <h2 class="text-xl font-black flex items-center gap-2">
              <svg class="w-5 h-5 text-[#e09e2b]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
              Recent Orders
            </h2>
            <a href="/orders" class="text-xs font-bold text-gray-500 hover:text-black transition">View All →</a>
          </div>
          <% if(recentOrders && recentOrders.length > 0) { %>
            <div class="space-y-3">
              <% recentOrders.forEach(order => { %>
                <a href="/orders/<%= order.id %>" class="flex items-center justify-between p-4 bg-gray-50 rounded-2xl border border-gray-100 hover:border-gray-300 transition group">
                  <div>
                    <p class="font-bold text-gray-900 text-sm">Order #<%= order.id %></p>
                    <p class="text-[11px] text-gray-400"><%= new Date(order.created_at).toLocaleDateString('en-IN') %></p>
                  </div>
                  <div class="text-right">
                    <p class="font-black text-gray-900 text-sm">₹<%= order.total %></p>
                    <% const statusColors = {
                      'Pending Verification': 'bg-yellow-100 text-yellow-700',
                      'Approved': 'bg-blue-100 text-blue-700',
                      'Shipped': 'bg-purple-100 text-purple-700',
                      'Delivered': 'bg-green-100 text-green-700',
                      'Cancelled': 'bg-red-100 text-red-600'
                    }; %>
                    <span class="text-[10px] font-bold px-2 py-0.5 rounded-full <%= statusColors[order.status] || 'bg-gray-100 text-gray-600' %>"><%= order.status %></span>
                  </div>
                </a>
              <% }) %>
            </div>
          <% } else { %>
            <div class="text-center py-8">
              <p class="text-gray-400 text-sm font-medium">No orders yet.</p>
              <a href="/shop" class="inline-block mt-3 text-xs font-bold text-[#e09e2b] hover:underline">Start Shopping →</a>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
