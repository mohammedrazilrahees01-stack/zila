            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-white/10 rounded-xl flex items-center justify-center flex-shrink-0">📍</div>
              <div>
                <p class="font-black text-white mb-1">Location</p>
                <p class="text-gray-400 text-sm font-medium leading-relaxed">Kannur, Kerala, India</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-white/10 rounded-xl flex items-center justify-center flex-shrink-0">📱</div>
              <div>
                <p class="font-black text-white mb-1">WhatsApp</p>
                <a href="https://wa.me/918075437816" target="_blank" class="text-[#f8bc45] hover:underline text-sm font-bold">+91 80754 37816</a>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-white/10 rounded-xl flex items-center justify-center flex-shrink-0">📧</div>
              <div>
                <p class="font-black text-white mb-1">Email</p>
                <a href="mailto:zilacollections@gmail.com" class="text-[#f8bc45] hover:underline text-sm font-bold">zilacollections@gmail.com</a>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-white/10 rounded-xl flex items-center justify-center flex-shrink-0">📱</div>
              <div>
                <p class="font-black text-white mb-1">Phone</p>
                <a href="tel:+918075437816" class="text-[#f8bc45] hover:underline text-sm font-bold">+91 80754 37816</a>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-white/10 rounded-xl flex items-center justify-center flex-shrink-0">📸</div>
              <div>
                <p class="font-black text-white mb-1">Instagram</p>
                <a href="https://instagram.com/zilacollections" target="_blank" class="text-[#f8bc45] hover:underline text-sm font-bold">@zilacollections</a>
              </div>
            </div>
          </div>

          <div class="mt-8 pt-8 border-t border-white/10">
            <a href="https://wa.me/918075437816?text=Hi Zila! I have a query 😊" target="_blank"
               class="flex items-center justify-center gap-2 bg-[#25D366] text-white px-6 py-3.5 rounded-xl font-bold hover:bg-green-600 transition w-full">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg>
