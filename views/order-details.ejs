<%- include('partials/header') %>

<section class="bg-[#fdf6ec] min-h-screen pt-32 pb-24 px-6 md:px-16 font-['Poppins']">
  <div class="max-w-3xl mx-auto">

    <!-- Back -->
    <a href="/orders" class="inline-flex items-center gap-2 text-gray-500 hover:text-black font-bold text-sm mb-8 transition group">
      <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      Back to Orders
    </a>

    <!-- Order Header Card -->
    <div class="bg-white rounded-3xl p-8 shadow-sm border border-gray-100 mb-6">
      <div class="flex flex-col md:flex-row justify-between items-start gap-4 mb-8">
        <div>
          <h1 class="text-3xl font-black text-gray-900 mb-1">Order #<%= order.id %></h1>
          <p class="text-gray-400 text-sm font-medium">Placed on <%= new Date(order.created_at).toLocaleDateString('en-IN', {weekday:'long', day:'numeric', month:'long', year:'numeric'}) %></p>
        </div>
        <% const statusConfig = {
          'Pending Verification': {bg:'bg-yellow-50', border:'border-yellow-300', text:'text-yellow-700', icon:'⏳', desc:'Awaiting payment verification'},
          'Approved': {bg:'bg-blue-50', border:'border-blue-300', text:'text-blue-700', icon:'✅', desc:'Payment approved, preparing order'},
          'Shipped': {bg:'bg-purple-50', border:'border-purple-300', text:'text-purple-700', icon:'🚚', desc:'Your order is on its way!'},
          'Delivered': {bg:'bg-green-50', border:'border-green-300', text:'text-green-700', icon:'📦', desc:'Order delivered successfully'},
          'Cancelled': {bg:'bg-red-50', border:'border-red-300', text:'text-red-600', icon:'❌', desc:'This order was cancelled'}
        };
        const sc = statusConfig[order.status] || {bg:'bg-gray-50', border:'border-gray-200', text:'text-gray-600', icon:'•', desc:''}; %>
        <div class="text-right">
          <span class="inline-flex items-center gap-2 <%= sc.bg %> border-2 <%= sc.border %> <%= sc.text %> font-black px-5 py-2.5 rounded-2xl text-sm">
            <%= sc.icon %> <%= order.status %>
          </span>
          <p class="text-[11px] text-gray-400 mt-1 font-medium"><%= sc.desc %></p>
        </div>
      </div>

      <!-- Order Progress Bar -->
      <% const statuses = ['Pending Verification', 'Approved', 'Shipped', 'Delivered'];
         const currentIdx = statuses.indexOf(order.status);
         const isCancelled = order.status === 'Cancelled'; %>
      <% if(!isCancelled) { %>
        <div class="relative mb-2">
          <div class="flex items-center">
            <% statuses.forEach((s, i) => { %>
              <div class="flex items-center flex-1 last:flex-none">
                <div class="flex flex-col items-center">
                  <div class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-black transition-all
                    <%= i <= currentIdx ? 'bg-[#f8bc45] text-black shadow-md' : 'bg-gray-200 text-gray-400' %>">
                    <%= i < currentIdx ? '✓' : i + 1 %>
                  </div>
                  <span class="text-[9px] font-bold mt-1 text-center <%= i <= currentIdx ? 'text-gray-900' : 'text-gray-400' %> max-w-[60px] leading-tight"><%= s.replace(' ', '\n') %></span>
                </div>
                <% if(i < statuses.length - 1) { %>
                  <div class="flex-1 h-1 rounded-full mx-2 mb-4 <%= i < currentIdx ? 'bg-[#f8bc45]' : 'bg-gray-200' %>"></div>
                <% } %>
              </div>
            <% }) %>
          </div>
        </div>
      <% } else { %>
        <div class="bg-red-50 border border-red-200 rounded-2xl p-4 text-center">
          <p class="text-red-600 font-bold text-sm">❌ This order has been cancelled.</p>
          <% if(order.cancel_reason) { %>
            <p class="text-red-500 text-xs mt-1">Reason: <%= order.cancel_reason %></p>
          <% } %>
        </div>
      <% } %>
    </div>

    <!-- Items -->
    <div class="bg-white rounded-3xl p-8 shadow-sm border border-gray-100 mb-6">
      <h2 class="text-xl font-black mb-6">Items Ordered</h2>
      <% const items = JSON.parse(order.items || '[]'); %>
      <div class="space-y-4">
        <% items.forEach(item => { %>
          <div class="flex items-center gap-5 p-4 bg-gray-50 rounded-2xl border border-gray-100">
            <div class="w-16 h-20 overflow-hidden rounded-xl bg-white flex-shrink-0">
              <img src="/images/<%= item.image %>" class="w-full h-full object-cover">
            </div>
            <div class="flex-1 min-w-0">
              <h4 class="font-bold text-gray-900 truncate"><%= item.name %></h4>
              <p class="text-xs text-gray-400 font-medium">Size: <span class="bg-white border text-gray-600 px-2 py-0.5 rounded-md font-bold"><%= item.size %></span></p>
              <p class="text-xs text-gray-500 mt-1 font-medium">Qty: <span class="font-bold"><%= item.qty %></span></p>
            </div>
            <p class="font-black text-gray-900 flex-shrink-0">₹<%= item.price * item.qty %></p>
          </div>
        <% }) %>
      </div>
      <div class="border-t border-gray-100 pt-5 mt-5 flex justify-between items-center">
        <span class="text-gray-500 font-medium">Order Total</span>
        <span class="text-2xl font-black text-black">₹<%= order.total %></span>
      </div>
    </div>

    <!-- Shipping Info -->
    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100">
        <h3 class="text-base font-black mb-4 flex items-center gap-2">
          <svg class="w-4 h-4 text-[#e09e2b]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
          Delivery Address
        </h3>
        <div class="text-sm text-gray-600 space-y-1 font-medium">
          <p class="font-black text-gray-900"><%= order.shipping_name %></p>
          <p><%= order.shipping_phone %></p>
          <p><%= order.shipping_address %></p>
          <p><%= order.shipping_city %>, <%= order.shipping_pincode %></p>
        </div>
      </div>
      <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100">
        <h3 class="text-base font-black mb-4 flex items-center gap-2">
          <svg class="w-4 h-4 text-[#e09e2b]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
          Payment Info
        </h3>
        <div class="text-sm text-gray-600 space-y-2 font-medium">
          <div class="flex justify-between">
            <span>Method</span>
            <span class="font-bold text-gray-900">UPI / QR Pay</span>
          </div>
          <div class="flex justify-between">
            <span>Reference</span>
            <span class="font-mono font-bold text-gray-900 text-xs"><%= order.payment_ref %></span>
          </div>
          <div class="flex justify-between">
            <span>Amount</span>
            <span class="font-black text-green-600">₹<%= order.total %></span>
          </div>
        </div>
      </div>
    </div>

    <!-- Actions -->
    <div class="flex flex-wrap gap-3 justify-center mt-6">
      <a href="https://wa.me/91XXXXXXXXXX?text=Hi Zila! Query about Order %23<%= order.id %>" target="_blank"
         class="inline-flex items-center gap-2 bg-[#25D366] text-white px-6 py-3 rounded-xl hover:bg-green-600 transition font-bold text-sm shadow-lg">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg>
        Contact Support
      </a>
      <a href="/shop" class="inline-flex items-center gap-2 bg-black text-white px-6 py-3 rounded-xl hover:bg-[#e09e2b] transition font-bold text-sm">
        Shop Again
      </a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
