<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Access — Zila</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>* { font-family: 'Poppins', sans-serif; }</style>
</head>
<body class="bg-gray-950 min-h-screen flex items-center justify-center p-6">
  <div class="w-full max-w-sm">
    <!-- Logo -->
    <div class="text-center mb-10">
      <div class="w-14 h-14 bg-[#f8bc45] rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-2xl">
        <span class="text-black font-black text-2xl">Z</span>
      </div>
      <h1 class="text-2xl font-black text-white">Admin Portal</h1>
      <p class="text-gray-500 font-medium text-xs mt-1 uppercase tracking-widest">Authorized Access Only</p>
    </div>

    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-8 shadow-2xl">
      <% if(locals.error) { %>
        <div class="bg-red-500/10 border border-red-500/20 text-red-400 font-bold text-sm p-3 rounded-xl mb-5 text-center">
          <%= error %>
        </div>
      <% } %>
      
      <form action="<%= loginRoute %>" method="POST" class="space-y-4">
        <div>
          <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Admin Email</label>
          <input type="email" name="email" placeholder="admin@zila.com" required
            class="w-full bg-gray-800 border-2 border-gray-700 text-white p-4 rounded-xl outline-none focus:border-[#f8bc45] font-medium text-sm transition">
        </div>
        <div>
          <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Password</label>
          <input type="password" name="password" placeholder="••••••••••" required
            class="w-full bg-gray-800 border-2 border-gray-700 text-white p-4 rounded-xl outline-none focus:border-[#f8bc45] font-medium text-sm transition">
        </div>
        <button type="submit" class="w-full bg-[#f8bc45] hover:bg-[#e09e2b] text-black font-black uppercase tracking-widest py-4 rounded-xl shadow-xl text-sm transition-all duration-300 mt-2">
          Access Dashboard
        </button>
      </form>
    </div>

    <div class="text-center mt-6">
      <a href="/" class="text-gray-600 hover:text-gray-400 text-xs font-medium transition">← Return to Store</a>
    </div>
  </div>
</body>
</html>
