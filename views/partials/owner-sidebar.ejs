<!-- Mobile owner topbar -->
<div class="md:hidden bg-gray-950 text-white px-4 py-3 flex items-center justify-between fixed top-0 left-0 right-0 z-40 border-b border-gray-800">
  <div class="flex items-center gap-3">
    <div class="w-8 h-8 bg-[#f8bc45] rounded-lg flex items-center justify-center"><span class="text-black font-black text-xs">Z</span></div>
    <span class="text-white font-black text-sm">ADMIN</span>
  </div>
  <button id="owner-mobile-btn" class="text-gray-400 p-1">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
  </button>
</div>
<!-- Mobile owner menu -->
<div id="owner-mobile-menu" class="md:hidden fixed inset-0 bg-gray-950 z-50 flex flex-col p-6 hidden">
  <div class="flex justify-between mb-8">
    <span class="text-[#f8bc45] font-black text-lg">ZILA ADMIN</span>
    <button id="owner-close-btn" class="text-gray-400"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button>
  </div>
  <nav class="flex flex-col gap-3">
    <a href="/owner" class="py-3 px-4 rounded-xl text-white font-bold bg-white/5">Dashboard</a>
    <a href="/owner/products" class="py-3 px-4 rounded-xl text-gray-400 font-bold hover:bg-white/5">Products</a>
    <a href="/owner/orders" class="py-3 px-4 rounded-xl text-gray-400 font-bold hover:bg-white/5">Orders</a>
    <a href="/owner/customers" class="py-3 px-4 rounded-xl text-gray-400 font-bold hover:bg-white/5">Customers</a>
    <a href="/owner/reviews" class="py-3 px-4 rounded-xl text-gray-400 font-bold hover:bg-white/5">Reviews</a>
    <a href="/owner/analytics" class="py-3 px-4 rounded-xl text-gray-400 font-bold hover:bg-white/5">Analytics</a>
    <a href="/logout" class="py-3 px-4 rounded-xl text-red-400 font-bold mt-4">Logout</a>
  </nav>
</div>
<script>
  const ownerBtn = document.getElementById('owner-mobile-btn');
  const ownerMenu = document.getElementById('owner-mobile-menu');
  const ownerClose = document.getElementById('owner-close-btn');
  if(ownerBtn) ownerBtn.addEventListener('click', () => ownerMenu.classList.remove('hidden'));
  if(ownerClose) ownerClose.addEventListener('click', () => ownerMenu.classList.add('hidden'));
</script>
