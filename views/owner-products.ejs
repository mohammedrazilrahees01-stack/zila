<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Products — Zila Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>* { font-family: 'Poppins', sans-serif; }</style>
  <% const currentPage = 'products'; %>
</head>
<body class="bg-gray-100 min-h-screen flex">
  <%- include('partials/owner-sidebar') %>

  <div class="flex-1 md:ml-64">
    <div class="md:p-8 p-4 pt-20 md:pt-8">

      <!-- Header -->
      <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
        <div>
          <h1 class="text-3xl font-black text-gray-900">Products</h1>
          <p class="text-gray-500 font-medium text-sm mt-1"><%= products.length %> products in your store</p>
        </div>
        <a href="/owner/products/add" class="inline-flex items-center gap-2 bg-[#f8bc45] text-black px-5 py-2.5 rounded-xl font-bold text-sm hover:bg-[#e09e2b] transition shadow-lg shadow-yellow-200">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          Add New Product
        </a>
      </div>

      <!-- Filter Bar -->
      <form action="/owner/products" method="GET" class="bg-white rounded-2xl p-4 mb-6 shadow-sm border border-gray-100 flex flex-wrap gap-3 items-end">
        <input type="text" name="search" value="<%= search || '' %>" placeholder="Search products..."
          class="flex-1 min-w-[160px] border border-gray-200 rounded-xl px-4 py-2.5 text-sm outline-none focus:border-[#f8bc45] font-medium">
        <select name="category" class="border border-gray-200 rounded-xl px-4 py-2.5 text-sm outline-none focus:border-[#f8bc45] font-medium">
          <option value="">All Categories</option>
          <option value="Topwear" <%= currentCategory === 'Topwear' ? 'selected' : '' %>>Topwear</option>
          <option value="Bottomwear" <%= currentCategory === 'Bottomwear' ? 'selected' : '' %>>Bottomwear</option>
        </select>
        <button type="submit" class="bg-gray-900 text-white px-5 py-2.5 rounded-xl font-bold text-sm hover:bg-[#e09e2b] transition">Filter</button>
        <a href="/owner/products" class="bg-gray-100 text-gray-600 px-4 py-2.5 rounded-xl font-bold text-sm hover:bg-gray-200 transition">Reset</a>
      </form>

      <!-- Products Table -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead class="bg-gray-50 border-b border-gray-100">
              <tr>
                <th class="text-left text-[10px] font-black text-gray-400 uppercase tracking-widest px-5 py-4 w-14">Image</th>
                <th class="text-left text-[10px] font-black text-gray-400 uppercase tracking-widest px-5 py-4">Product</th>
                <th class="text-left text-[10px] font-black text-gray-400 uppercase tracking-widest px-5 py-4">Category</th>
                <th class="text-left text-[10px] font-black text-gray-400 uppercase tracking-widest px-5 py-4">Price</th>
                <th class="text-left text-[10px] font-black text-gray-400 uppercase tracking-widest px-5 py-4">Stock</th>
                <th class="text-left text-[10px] font-black text-gray-400 uppercase tracking-widest px-5 py-4">Status</th>
                <th class="text-left text-[10px] font-black text-gray-400 uppercase tracking-widest px-5 py-4">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
              <% if(products && products.length > 0) { %>
                <% products.forEach(p => { %>
                  <tr class="hover:bg-gray-50 transition group">
                    <td class="px-5 py-4">
                      <div class="w-12 h-14 overflow-hidden rounded-xl bg-gray-100">
                        <img src="/images/<%= p.image %>" class="w-full h-full object-cover">
                      </div>
                    </td>
                    <td class="px-5 py-4">
                      <p class="font-bold text-gray-900 text-sm"><%= p.name %></p>
                      <p class="text-[10px] text-gray-400 font-mono mt-0.5">ID: #<%= p.id %></p>
                    </td>
                    <td class="px-5 py-4">
                      <span class="bg-gray-100 text-gray-700 px-2.5 py-1 rounded-full text-[11px] font-bold"><%= p.category %></span>
                    </td>
                    <td class="px-5 py-4">
                      <% if(p.offer_price && p.offer_price > 0 && p.offer_price < p.price) { %>
                        <p class="font-black text-gray-900 text-sm">₹<%= p.offer_price %></p>
                        <p class="text-[10px] text-gray-400 line-through">₹<%= p.price %></p>
                      <% } else { %>
                        <p class="font-black text-gray-900 text-sm">₹<%= p.price %></p>
                      <% } %>
                    </td>
                    <td class="px-5 py-4">
                      <% if(p.stock === 0) { %>
                        <span class="text-red-600 font-black text-sm bg-red-50 px-2.5 py-1 rounded-full">Out of Stock</span>
                      <% } else if(p.stock <= 5) { %>
                        <span class="text-orange-600 font-black text-sm bg-orange-50 px-2.5 py-1 rounded-full"><%= p.stock %> left ⚠️</span>
                      <% } else { %>
                        <span class="text-green-600 font-bold text-sm"><%= p.stock %> in stock</span>
                      <% } %>
                    </td>
                    <td class="px-5 py-4">
                      <% if(p.featured) { %>
                        <span class="bg-[#f8bc45] text-black text-[10px] font-black px-2.5 py-1 rounded-full">Featured</span>
                      <% } else { %>
                        <span class="bg-gray-100 text-gray-500 text-[10px] font-bold px-2.5 py-1 rounded-full">Standard</span>
                      <% } %>
                    </td>
                    <td class="px-5 py-4">
                      <div class="flex items-center gap-2">
                        <a href="/owner/products/edit/<%= p.id %>" class="bg-gray-100 hover:bg-[#f8bc45] text-gray-700 hover:text-black p-2 rounded-lg transition">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                        </a>
                        <form action="/delete-product/<%= p.id %>" method="POST" onsubmit="return confirm('Delete <%= p.name %>? This cannot be undone.')">
                          <button type="submit" class="bg-gray-100 hover:bg-red-100 text-gray-700 hover:text-red-600 p-2 rounded-lg transition">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                          </button>
                        </form>
                        <a href="/product/<%= p.id %>" target="_blank" class="bg-gray-100 hover:bg-blue-50 text-gray-700 hover:text-blue-600 p-2 rounded-lg transition">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                        </a>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr><td colspan="7" class="text-center py-16 text-gray-400">
                  <p class="text-4xl mb-3">📦</p>
                  <p class="font-bold">No products found</p>
                </td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
