<%- include('partials/header') %>

<section class="bg-[#fdf6ec] min-h-screen pt-32 pb-24 px-6 md:px-16 font-['Poppins']">
  <div class="container mx-auto max-w-4xl">

    <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-10 pb-6 border-b border-gray-200">
      <div>
        <span class="text-[#e09e2b] text-xs font-black uppercase tracking-widest block mb-1">Account</span>
        <h1 class="text-4xl font-black text-gray-900 tracking-tighter">My Orders</h1>
        <p class="text-gray-500 mt-2 font-medium">Track your recent purchases.</p>
      </div>
      <div class="flex gap-3 mt-4 md:mt-0">
        <a href="/account" class="text-sm font-bold text-gray-500 hover:text-black transition border border-gray-200 px-4 py-2 rounded-xl bg-white">← Account</a>
        <a href="/shop" class="relative overflow-hidden glass-btn btn-shine text-white text-sm font-bold px-4 py-2 rounded-xl">Shop More</a>
      </div>
    </div>

    <% if(orders && orders.length > 0) { %>
      <div class="space-y-5">
        <% orders.forEach(order => { %>
          <div class="bg-white p-6 md:p-8 rounded-3xl shadow-sm border border-gray-100 hover:shadow-md hover:border-gray-200 transition-all duration-300 group">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">

              <!-- Left Info -->
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-3">
                  <span class="text-xs font-mono bg-gray-100 text-gray-600 px-3 py-1 rounded-full">Order #<%= order.id %></span>
                  <span class="text-xs text-gray-400 font-medium"><%= new Date(order.created_at).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric'}) %></span>
                </div>
                <p class="text-2xl font-black text-gray-900 mb-1">₹<%= order.total %></p>
                <p class="text-xs text-gray-400 font-mono">Ref: <%= order.payment_ref %></p>
              </div>

              <!-- Status -->
              <div class="flex flex-col md:items-end gap-3">
                <% const statusConfig = {
                  'Pending Verification': {bg:'bg-yellow-50', border:'border-yellow-200', text:'text-yellow-700', icon:'⏳'},
                  'Approved': {bg:'bg-blue-50', border:'border-blue-200', text:'text-blue-700', icon:'✅'},
                  'Shipped': {bg:'bg-purple-50', border:'border-purple-200', text:'text-purple-700', icon:'🚚'},
                  'Delivered': {bg:'bg-green-50', border:'border-green-200', text:'text-green-700', icon:'📦'},
                  'Cancelled': {bg:'bg-red-50', border:'border-red-200', text:'text-red-600', icon:'❌'}
                };
                const sc = statusConfig[order.status] || {bg:'bg-gray-50', border:'border-gray-200', text:'text-gray-600', icon:'•'}; %>
                <span class="inline-flex items-center gap-2 <%= sc.bg %> <%= sc.border %> border <%= sc.text %> font-bold px-4 py-2 rounded-xl text-sm">
                  <%= sc.icon %> <%= order.status %>
                </span>
                <a href="/orders/<%= order.id %>" class="inline-flex items-center gap-2 text-sm font-bold text-gray-700 bg-gray-50 border border-gray-200 px-5 py-2.5 rounded-xl hover:bg-black hover:text-white hover:border-black transition-all group">
                  View Details
                  <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="text-center bg-white rounded-3xl p-16 shadow-sm border border-gray-100">
        <div class="w-24 h-24 bg-[#fdf6ec] rounded-full flex items-center justify-center mx-auto mb-6 text-4xl border-4 border-[#f8bc45]/30">📦</div>
        <h2 class="text-2xl font-black mb-3 text-gray-900">No orders yet</h2>
        <p class="text-gray-500 font-medium mb-8">You haven't placed any orders. Start shopping and find something you love!</p>
        <a href="/shop" class="inline-block relative overflow-hidden glass-btn btn-shine text-white px-10 py-4 rounded-xl font-black uppercase tracking-widest shadow-xl text-sm">
          Start Shopping
        </a>
      </div>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>
