<%- include('partials/header') %>

<style>
    /* Custom Colors from the image */
    :root {
        --peach: #fac5b5;
        --yellow: #f8bc45;
        --mustard: #e09e2b;
    }

    /* Organic Peach Background */
    .hero-peach-bg {
        position: absolute;
        top: 0;
        left: 0;
        width: 65%;
        height: 100%;
        background-color: var(--peach);
        /* Creates the wavy right edge */
        clip-path: polygon(0 0, 100% 0, 85% 50%, 95% 100%, 0 100%);
        z-index: 0;
    }

    /* Floating Animations */
    @keyframes float {
        0% { transform: translateY(0px) rotate(0deg); }
        50% { transform: translateY(-15px) rotate(10deg); }
        100% { transform: translateY(0px) rotate(0deg); }
    }
    .floating-shape {
        animation: float 6s ease-in-out infinite;
    }

    /* Button Styling */
    .btn-buy {
        background: var(--mustard);
        color: white;
        padding: 12px 32px;
        border-radius: 50px;
        font-weight: 700;
        letter-spacing: 1px;
        font-size: 0.9rem;
        transition: all 0.3s ease;
        text-transform: uppercase;
        box-shadow: 0 10px 20px rgba(224, 158, 43, 0.3);
    }
    .btn-buy:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 25px rgba(224, 158, 43, 0.4);
    }
</style>

<!-- HERO SECTION -->
<section class="relative w-full min-h-screen pt-32 pb-20 flex items-center bg-[#f8bc45] overflow-hidden">
    
    <!-- Organic Background Layer -->
    <div class="hero-peach-bg"></div>

    <!-- Decorative Top Blob -->
    <div class="absolute top-[-5%] left-[25%] w-48 h-32 bg-[#e84f4f] rounded-full mix-blend-multiply opacity-80 filter blur-xl z-0"></div>
    <div class="absolute top-[20%] left-[22%] w-16 h-10 bg-yellow-500 rounded-full rotate-[-20deg] z-0"></div>

    <!-- Decorative Bottom Elements -->
    <!-- Line Art Hills -->
    <svg class="absolute bottom-0 left-[5%] w-64 h-32 z-10" viewBox="0 0 200 100" fill="none" stroke="white" stroke-width="2">
        <path d="M0 100 Q 20 40 50 60 T 100 20 T 150 70 T 200 30" stroke-linecap="round"/>
        <path d="M20 100 Q 40 60 70 80 T 120 40 T 170 90" stroke-linecap="round"/>
    </svg>
    <!-- Mustard Blob Bottom Left -->
    <div class="absolute bottom-[-10%] left-[-5%] w-64 h-64 bg-[#e09e2b] rounded-full z-0"></div>
    
    <!-- Floating Red Leaves -->
    <div class="floating-shape absolute bottom-[25%] left-[40%] w-6 h-6 bg-[#e84f4f] rounded-tl-full rounded-br-full rotate-45 z-10"></div>
    <div class="floating-shape absolute bottom-[15%] left-[42%] w-4 h-4 bg-[#e84f4f] rounded-tl-full rounded-br-full rotate-[70deg] z-10" style="animation-delay: 1s;"></div>
    <div class="floating-shape absolute bottom-[20%] left-[46%] w-3 h-3 bg-[#e84f4f] rounded-tl-full rounded-br-full rotate-12 z-10" style="animation-delay: 2s;"></div>

    <!-- CONTENT GRID -->
    <div class="relative z-20 container mx-auto px-8 md:px-16 grid md:grid-cols-2 items-center gap-12">
        
        <!-- LEFT: Text Content -->
        <div class="pt-10">
            <h1 class="text-white text-7xl md:text-8xl lg:text-[110px] font-black leading-[1.1] tracking-tighter mb-6 drop-shadow-sm">
                FASHION<br>SALE
            </h1>
            
            <p class="text-white/90 font-medium mb-10 max-w-md text-lg leading-relaxed">
                Lorem ipsum dolor sit amet, consectetur adipiscing elit. 
                Vestibulum lorem odio luctus egestas.
            </p>

            <a href="/shop" class="btn-buy inline-block">
                BUY NOW
            </a>
        </div>

        <!-- RIGHT: Image -->
        <!-- Replace this URL with your model image. I provided an Unsplash image that perfectly matches the yellow vibe -->
        <div class="relative flex justify-center items-center h-full mt-10 md:mt-0">
            <img src="https://images.unsplash.com/photo-1552374196-1ab2a1c593e8?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" 
                 alt="Fashion Model" 
                 class="relative z-10 w-full max-w-[500px] h-[600px] object-cover rounded-3xl drop-shadow-2xl">
        </div>

    </div>
</section>


<!-- PRODUCTS SECTION (Retaining your backend logic) -->
<section class="bg-[#fdf6ec] px-8 md:px-20 py-24 relative z-20 rounded-t-[3rem] mt-[-2rem] shadow-[0_-20px_40px_rgba(0,0,0,0.05)]">

    <div class="text-center mb-16">
        <h2 class="text-4xl font-black text-gray-900 tracking-tight">LATEST DROPS</h2>
        <div class="w-24 h-1 bg-[#e09e2b] mx-auto mt-4 rounded-full"></div>
    </div>

    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-10">
        <!-- YOUR BACKEND LOGIC HERE -->
        <% products.forEach(p => { %>

        <div class="bg-white p-6 rounded-3xl shadow-lg hover:shadow-2xl transition duration-300 group">
            <div class="overflow-hidden rounded-2xl mb-6">
                <img src="/images/<%= p.image %>" class="h-72 w-full object-cover group-hover:scale-105 transition duration-500">
            </div>
            
            <h3 class="text-xl font-bold text-gray-900 mb-2"><%= p.name %></h3>
            <p class="text-[#e09e2b] font-bold text-lg mb-6">₹ <%= p.price %></p>

            <a href="/product/<%= p.id %>" class="block text-center bg-gray-900 text-white py-3 rounded-full font-semibold hover:bg-[#e09e2b] transition">
                View Product
            </a>
        </div>

        <% }) %>
    </div>

</section>

<%- include('partials/footer') %>