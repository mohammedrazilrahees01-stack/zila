<%- include('partials/header') %>

<!-- HERO SECTION -->
<section class="relative w-full min-h-[92vh] pt-24 pb-20 flex items-center bg-[#f8bc45] overflow-hidden">
  <!-- Split Background -->
  <div class="absolute top-0 left-0 w-[60%] h-full bg-[#fac5b5] z-0" style="clip-path: polygon(0 0, 100% 0, 82% 50%, 95% 100%, 0 100%);"></div>

  <!-- Floating Decorative Elements -->
  <div class="absolute top-[15%] left-[18%] w-20 h-12 bg-yellow-400 rounded-full rotate-[-20deg] z-0 opacity-40 blur-sm"></div>
  <div class="absolute bottom-[20%] left-[38%] w-8 h-8 bg-[#e84f4f] rounded-full z-0 animate-bounce" style="animation-duration:3s"></div>
  <div class="absolute top-[60%] right-[5%] w-6 h-6 bg-white/40 rounded-full z-0 animate-pulse"></div>
  <div class="absolute top-[10%] right-[10%] w-40 h-40 border-4 border-white/20 rounded-full z-0"></div>

  <!-- CONTENT -->
  <div class="relative z-20 container mx-auto px-8 md:px-16 grid md:grid-cols-2 items-center gap-12">
    <!-- LEFT: Text -->
    <div class="pt-10">
      <div class="inline-flex items-center gap-2 bg-black/10 backdrop-blur-sm px-4 py-2 rounded-full mb-6">
        <span class="w-2 h-2 bg-white rounded-full animate-pulse"></span>
        <span class="text-white/90 text-xs font-bold uppercase tracking-widest">New Collection 2024</span>
      </div>
      <h1 class="text-white text-6xl md:text-8xl lg:text-[90px] font-black leading-[1] tracking-tighter mb-6 drop-shadow-md">
        FASHION<br><span class="text-black">SALE</span>
      </h1>
      <p class="text-white/90 font-medium mb-10 max-w-md text-lg leading-relaxed">
        Premium streetwear from Kannur. Bold designs, flawless fits, unmatched quality — built for those who wear their identity.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/shop" class="relative overflow-hidden bg-black text-white px-10 py-4 rounded-full font-bold uppercase tracking-widest text-sm transition-all hover:-translate-y-1 shadow-2xl hover:shadow-black/40 btn-shine inline-block text-center">
          Shop Now
        </a>
        <a href="/about" class="bg-white/20 backdrop-blur-sm text-white border border-white/30 px-8 py-4 rounded-full font-bold uppercase tracking-widest text-sm hover:bg-white/30 transition-all inline-block text-center">
          Our Story
        </a>
      </div>
    </div>

    <!-- RIGHT: Image -->
    <div class="relative flex justify-center items-end h-full mt-10 md:mt-0">
      <div class="relative">
        <!-- Glow effect -->
        <div class="absolute inset-0 bg-[#f8bc45]/50 blur-3xl rounded-full scale-75 z-0"></div>
        <img src="https://images.unsplash.com/photo-1552374196-1ab2a1c593e8?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
             alt="Fashion Model"
             class="relative z-10 w-full max-w-[420px] h-[520px] object-cover rounded-[2rem] shadow-2xl border-4 border-white/20">
        <!-- Floating card -->
        <div class="absolute -bottom-4 -left-8 z-20 bg-white/80 backdrop-blur-xl border border-white/60 rounded-2xl p-4 shadow-xl">
          <p class="text-[10px] text-gray-500 font-bold uppercase tracking-widest">Limited Drop</p>
          <p class="text-black font-black text-lg">New Arrivals</p>
          <div class="flex items-center gap-1 mt-1">
            <span class="text-[#f8bc45] text-sm">★★★★★</span>
            <span class="text-gray-500 text-[10px]">4.9 (200+)</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- MARQUEE TICKER -->
<div class="bg-black py-4 overflow-hidden">
  <div class="flex gap-12 animate-marquee whitespace-nowrap" style="animation: marquee 20s linear infinite;">
    <% ['Free Shipping on Orders ₹1999+', 'New Drops Every Week', 'Premium Streetwear', 'Made in India 🇮🇳', 'Limited Edition Pieces', 'Exclusive Designs'].forEach(t => { %>
      <span class="text-[#f8bc45] font-black uppercase tracking-widest text-sm inline-flex items-center gap-4">
        <span>✦</span> <%= t %> 
      </span>
    <% }) %>
    <% ['Free Shipping on Orders ₹1999+', 'New Drops Every Week', 'Premium Streetwear', 'Made in India 🇮🇳', 'Limited Edition Pieces', 'Exclusive Designs'].forEach(t => { %>
      <span class="text-[#f8bc45] font-black uppercase tracking-widest text-sm inline-flex items-center gap-4">
        <span>✦</span> <%= t %> 
      </span>
    <% }) %>
  </div>
</div>
<style>@keyframes marquee { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }</style>

<!-- CATEGORIES SECTION -->
<section class="bg-white px-6 md:px-16 py-20">
  <div class="container mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-4xl font-black tracking-tight text-gray-900">SHOP BY CATEGORY</h2>
      <div class="w-16 h-1.5 bg-[#f8bc45] mx-auto mt-4 rounded-full"></div>
    </div>
    <div class="grid grid-cols-2 gap-6">
      <a href="/shop?category=Topwear" class="group relative overflow-hidden rounded-3xl aspect-[3/2] bg-[#fac5b5]">
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent z-10"></div>
        <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition z-10"></div>
        <img src="https://images.unsplash.com/photo-1583743814966-8936f5b7be1a?auto=format&fit=crop&w=800&q=80" alt="Topwear" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
        <div class="absolute bottom-6 left-6 z-20">
          <h3 class="text-white font-black text-2xl md:text-3xl tracking-tight">TOPWEAR</h3>
          <p class="text-white/70 text-sm font-medium group-hover:text-[#f8bc45] transition">Shop Collection →</p>
        </div>
      </a>
      <a href="/shop?category=Bottomwear" class="group relative overflow-hidden rounded-3xl aspect-[3/2] bg-[#f8bc45]">
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent z-10"></div>
        <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition z-10"></div>
        <img src="https://images.unsplash.com/photo-1542272604-787c3835535d?auto=format&fit=crop&w=800&q=80" alt="Bottomwear" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
        <div class="absolute bottom-6 left-6 z-20">
          <h3 class="text-white font-black text-2xl md:text-3xl tracking-tight">BOTTOMWEAR</h3>
          <p class="text-white/70 text-sm font-medium group-hover:text-[#f8bc45] transition">Shop Collection →</p>
        </div>
      </a>
    </div>
  </div>
</section>

<!-- FEATURED / LATEST DROPS -->
<section class="bg-[#fdf6ec] px-6 md:px-16 py-24">
  <div class="container mx-auto">
    <div class="flex flex-col md:flex-row justify-between items-end mb-16">
      <div>
        <span class="text-[#e09e2b] text-xs font-black uppercase tracking-widest mb-2 block">Fresh Arrivals</span>
        <h2 class="text-4xl md:text-5xl font-black text-gray-900 tracking-tight">LATEST DROPS</h2>
        <div class="w-24 h-1.5 bg-[#f8bc45] mt-4 rounded-full"></div>
      </div>
      <a href="/shop" class="hidden md:inline-flex items-center gap-2 text-sm font-black uppercase tracking-widest text-gray-500 hover:text-black transition group">
        View All
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
      <% products.forEach(product => { %>
        <a href="/product/<%= product.id %>" class="group block product-card">
          <div class="relative w-full aspect-[4/5] overflow-hidden rounded-2xl bg-white mb-4 shadow-sm group-hover:shadow-2xl transition-all duration-500">
            <% if(product.offer_price && product.offer_price > 0 && product.offer_price < product.price) { %>
              <div class="absolute top-3 left-3 z-10 flex flex-col gap-1">
                <span class="bg-[#f8bc45] text-black text-[9px] font-black px-2.5 py-1 rounded-full uppercase tracking-wide">Sale</span>
                <span class="bg-black text-white text-[9px] font-black px-2.5 py-1 rounded-full">
                  -<%= Math.round((product.price - product.offer_price) / product.price * 100) %>%
                </span>
              </div>
            <% } else if(product.stock > 0 && product.stock <= 5) { %>
              <span class="absolute top-3 left-3 bg-red-500 text-white text-[9px] font-black px-2.5 py-1 rounded-full z-10 uppercase">Few Left</span>
            <% } else if(product.featured) { %>
              <span class="absolute top-3 left-3 bg-black text-[#f8bc45] text-[9px] font-black px-2.5 py-1 rounded-full z-10 uppercase">Featured</span>
            <% } %>
            
            <img src="/images/<%= product.image %>" class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-700 ease-in-out">
            
            <!-- Quick add overlay -->
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-all duration-300 flex items-end justify-center pb-4">
              <span class="bg-white/90 backdrop-blur-sm text-black font-bold text-xs px-4 py-2 rounded-full opacity-0 group-hover:opacity-100 transform translate-y-2 group-hover:translate-y-0 transition-all duration-300 uppercase tracking-wide">
                View Product
              </span>
            </div>
          </div>
          <div class="px-1">
            <p class="text-[10px] text-gray-400 uppercase font-bold tracking-wider mb-1"><%= product.category %></p>
            <h3 class="text-base font-bold text-gray-900 mb-1 leading-tight group-hover:text-[#e09e2b] transition truncate"><%= product.name %></h3>
            <div class="flex items-center gap-2">
              <% if(product.offer_price && product.offer_price > 0 && product.offer_price < product.price) { %>
                <span class="text-black font-black text-base">₹<%= product.offer_price %></span>
                <span class="text-gray-400 text-sm line-through font-medium">₹<%= product.price %></span>
              <% } else { %>
                <span class="text-black font-black text-base">₹<%= product.price %></span>
              <% } %>
            </div>
          </div>
        </a>
      <% }) %>
    </div>

    <div class="text-center mt-12">
      <a href="/shop" class="inline-flex items-center gap-3 border-2 border-black text-black font-bold uppercase tracking-widest px-10 py-4 rounded-xl hover:bg-black hover:text-white transition-all duration-300 group">
        View All Products
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<!-- WHY CHOOSE US -->
<section class="bg-black text-white px-6 md:px-16 py-20">
  <div class="container mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-black tracking-tight">WHY ZILA?</h2>
      <p class="text-gray-400 mt-4 font-medium">Everything you need, nothing you don't.</p>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      <% [
        {icon: '🚀', title: 'Fast Shipping', desc: '3-5 business days PAN India'},
        {icon: '💎', title: 'Premium Quality', desc: 'Carefully curated fabrics'},
        {icon: '🔄', title: 'Easy Returns', desc: '7-day hassle-free returns'},
        {icon: '🔒', title: 'Secure Payment', desc: 'UPI & QR Pay supported'}
      ].forEach(f => { %>
        <div class="group bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-6 text-center hover:bg-white/10 hover:border-[#f8bc45]/50 transition-all duration-300 hover:-translate-y-1">
          <div class="text-3xl mb-4"><%= f.icon %></div>
          <h3 class="font-black text-white text-sm mb-2 uppercase tracking-wide"><%= f.title %></h3>
          <p class="text-gray-400 text-xs leading-relaxed"><%= f.desc %></p>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- SOCIAL PROOF BANNER -->
<section class="bg-[#fdf6ec] py-20 px-6 md:px-16">
  <div class="container mx-auto text-center">
    <h2 class="text-3xl md:text-5xl font-black tracking-tight text-gray-900 mb-4">WORN BY THE <span class="text-[#e09e2b]">BOLD</span></h2>
    <p class="text-gray-500 mb-10 font-medium">Join 10,000+ customers who've upgraded their wardrobe.</p>
    <a href="/shop" class="relative overflow-hidden glass-btn btn-shine text-white px-12 py-4 rounded-2xl font-black uppercase tracking-widest text-sm shadow-2xl inline-block">
      Explore Collection
    </a>
  </div>
</section>

<%- include('partials/footer') %>
