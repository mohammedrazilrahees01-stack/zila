<%- include('partials/header') %>

<section class="bg-[#fdf6ec] min-h-screen flex items-center justify-center pt-32 pb-20 px-6 font-['Poppins']">
    <div class="bg-white p-8 md:p-12 rounded-3xl shadow-xl w-full max-w-2xl border border-gray-100 relative overflow-hidden">
        
        <!-- Decorative Header Graphic -->
        <div class="absolute top-0 left-0 w-full h-4 bg-[#f8bc45]"></div>

        <div class="text-center mb-8 pt-4">
            <div class="w-20 h-20 bg-green-100 text-green-500 rounded-full flex items-center justify-center mx-auto mb-4 text-4xl shadow-sm">
                ✅
            </div>
            <h1 class="text-3xl font-black text-gray-900 tracking-tight">Order Received!</h1>
            <p class="text-gray-500 mt-2">Thank you for shopping with Zila Collections.</p>
            <p class="text-xs font-bold bg-gray-100 inline-block px-3 py-1 rounded-full mt-3">Order #<%= order.id %></p>
        </div>

        <!-- Order Info -->
        <div class="bg-gray-50 p-6 rounded-2xl mb-8 border border-gray-100 grid md:grid-cols-2 gap-4 text-sm">
            <div>
                <p class="text-gray-400 font-bold uppercase tracking-wider text-[10px] mb-1">Shipping To</p>
                <p class="font-bold text-gray-900"><%= order.name %></p>
                <p class="text-gray-600"><%= order.address %><br><%= order.city %>, <%= order.pincode %></p>
            </div>
            <div>
                <p class="text-gray-400 font-bold uppercase tracking-wider text-[10px] mb-1">Payment Status</p>
                <p class="font-bold text-[#e09e2b]"><%= order.status %></p>
                <p class="text-gray-500 font-mono text-xs mt-1">Ref: <%= order.payment_ref %></p>
            </div>
        </div>

        <!-- Items Summary -->
        <h3 class="font-black text-lg mb-4 border-b pb-2">Order Items</h3>
        <div class="space-y-4 mb-8">
            <% items.forEach(item => { %>
                <div class="flex justify-between items-center text-sm font-medium">
                    <div class="flex items-center gap-4">
                        <span class="bg-gray-100 text-gray-500 px-2 py-1 rounded text-xs font-bold"><%= item.quantity %>x</span>
                        <span class="text-gray-900"><%= item.product_name %> <span class="text-gray-400 text-xs">(<%= item.size %>)</span></span>
                    </div>
                    <span class="text-gray-900 font-bold">₹<%= item.price * item.quantity %></span>
                </div>
            <% }) %>
        </div>

        <div class="flex justify-between items-center border-t border-gray-200 pt-6">
            <span class="text-xl font-bold">Total Paid</span>
            <span class="text-3xl font-black text-[#e09e2b]">₹<%= order.total %></span>
        </div>

        <div class="mt-10 text-center space-x-4">
            <a href="/orders" class="inline-block bg-black text-white px-8 py-3 rounded-xl font-bold hover:bg-[#e09e2b] transition">View My Orders</a>
            <a href="/shop" class="inline-block text-gray-500 font-bold hover:text-black transition underline">Continue Shopping</a>
        </div>
    </div>
</section>

<%- include('partials/footer') %>