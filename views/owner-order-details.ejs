<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Order #<%= order.id %> — Zila Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>* { font-family: 'Poppins', sans-serif; }</style>
  <% const currentPage = 'orders'; %>
</head>
<body class="bg-gray-100 min-h-screen flex">
  <%- include('partials/owner-sidebar') %>

  <div class="flex-1 md:ml-64">
    <div class="md:p-8 p-4 pt-20 md:pt-8 max-w-4xl">

      <div class="flex items-center gap-4 mb-8">
        <a href="/owner/orders" class="text-gray-400 hover:text-black transition">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        </a>
        <div>
          <h1 class="text-3xl font-black text-gray-900">Order #<%= order.id %></h1>
          <p class="text-gray-500 text-sm font-medium"><%= new Date(order.created_at).toLocaleString('en-IN') %></p>
        </div>
        <div class="ml-auto">
          <% const statusColors = {'Pending Verification':'bg-yellow-100 text-yellow-800','Approved':'bg-blue-100 text-blue-800','Shipped':'bg-purple-100 text-purple-800','Delivered':'bg-green-100 text-green-800','Cancelled':'bg-red-100 text-red-800'}; %>
          <span class="font-bold px-4 py-2 rounded-xl text-sm <%= statusColors[order.status] || 'bg-gray-100 text-gray-700' %>"><%= order.status %></span>
        </div>
      </div>

      <div class="grid md:grid-cols-3 gap-6">

        <!-- Left Col (2/3) -->
        <div class="md:col-span-2 space-y-6">
          <!-- Items -->
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="p-5 border-b border-gray-100">
              <h2 class="font-black text-gray-900">Order Items</h2>
            </div>
            <% const items = JSON.parse(order.items || '[]'); %>
            <div class="divide-y divide-gray-50">
              <% items.forEach(item => { %>
                <div class="flex items-center gap-4 p-5">
                  <div class="w-14 h-20 overflow-hidden rounded-xl bg-gray-100 flex-shrink-0">
                    <img src="/images/<%= item.image %>" class="w-full h-full object-cover">
                  </div>
                  <div class="flex-1">
                    <p class="font-bold text-gray-900"><%= item.name %></p>
                    <p class="text-xs text-gray-400 mt-1">Size: <span class="font-bold text-gray-600"><%= item.size %></span></p>
                    <p class="text-xs text-gray-400">Qty: <span class="font-bold"><%= item.qty %></span> × ₹<%= item.price %></p>
                  </div>
                  <p class="font-black text-gray-900">₹<%= item.price * item.qty %></p>
                </div>
              <% }) %>
            </div>
            <div class="p-5 border-t-2 border-gray-900 flex justify-between">
              <span class="font-black text-gray-900">Total</span>
              <span class="text-2xl font-black text-gray-900">₹<%= order.total %></span>
            </div>
          </div>

          <!-- Update Status -->
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
            <h2 class="font-black text-gray-900 mb-5">Update Order Status</h2>

            <% if(order.status === 'Pending Verification') { %>
              <div class="grid grid-cols-2 gap-3">
                <form action="/owner/orders/<%= order.id %>/status" method="POST">
                  <input type="hidden" name="status" value="Approved">
                  <button type="submit" class="w-full bg-green-500 hover:bg-green-600 text-white font-bold py-3.5 rounded-xl text-sm transition shadow-lg shadow-green-100">
                    ✅ Approve & Confirm
                  </button>
                </form>
                <button type="button" onclick="document.getElementById('cancel-form').classList.toggle('hidden')"
                  class="w-full bg-red-100 hover:bg-red-200 text-red-600 font-bold py-3.5 rounded-xl text-sm transition">
                  ❌ Reject Payment
                </button>
              </div>
              <div id="cancel-form" class="hidden mt-4">
                <form action="/owner/orders/<%= order.id %>/status" method="POST" class="space-y-3">
                  <input type="hidden" name="status" value="Cancelled">
                  <textarea name="cancel_reason" rows="2" placeholder="Reason for rejection (e.g. Payment reference invalid)"
                    class="w-full border-2 border-red-200 p-3 rounded-xl text-sm font-medium outline-none resize-none" required></textarea>
                  <button type="submit" class="w-full bg-red-500 hover:bg-red-600 text-white font-bold py-3 rounded-xl text-sm transition">
                    Confirm Rejection
                  </button>
                </form>
              </div>
            <% } else if(order.status !== 'Cancelled' && order.status !== 'Delivered') { %>
              <form action="/owner/orders/<%= order.id %>/status" method="POST">
                <div class="flex gap-3">
                  <select name="status" class="flex-1 border-2 border-gray-200 p-3 rounded-xl font-bold text-sm outline-none focus:border-[#f8bc45]">
                    <option value="Approved" <%= order.status === 'Approved' ? 'selected' : '' %>>Approved</option>
                    <option value="Shipped" <%= order.status === 'Shipped' ? 'selected' : '' %>>Shipped</option>
                    <option value="Delivered" <%= order.status === 'Delivered' ? 'selected' : '' %>>Delivered</option>
                    <option value="Cancelled">Cancelled</option>
                  </select>
                  <button type="submit" class="bg-[#f8bc45] hover:bg-[#e09e2b] text-black font-bold px-6 py-3 rounded-xl text-sm transition">
                    Update
                  </button>
                </div>
                <div id="cancel-form-update" class="hidden mt-3">
                  <textarea name="cancel_reason" rows="2" placeholder="Reason for cancellation" class="w-full border-2 border-red-200 p-3 rounded-xl text-sm font-medium outline-none resize-none"></textarea>
                </div>
              </form>
              <script>
                document.querySelector('select[name="status"]').addEventListener('change', function() {
                  document.getElementById('cancel-form-update').classList.toggle('hidden', this.value !== 'Cancelled');
                });
              </script>
            <% } else { %>
              <div class="bg-gray-50 rounded-xl p-4 text-center">
                <p class="text-gray-500 font-medium text-sm">
                  <%= order.status === 'Delivered' ? '✅ Order completed — no further actions needed.' : '❌ Order cancelled.' %>
                </p>
                <% if(order.cancel_reason) { %>
                  <p class="text-red-500 text-xs mt-1">Reason: <%= order.cancel_reason %></p>
                <% } %>
              </div>
            <% } %>
          </div>
        </div>

        <!-- Right Col (1/3) -->
        <div class="space-y-5">
          <!-- Customer Info -->
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5">
            <h3 class="font-black text-gray-900 mb-4 flex items-center gap-2">
              <svg class="w-4 h-4 text-[#e09e2b]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
              Customer
            </h3>
            <div class="space-y-2 text-sm font-medium">
              <p class="font-black text-gray-900"><%= order.shipping_name %></p>
              <p class="text-gray-500"><%= order.shipping_phone %></p>
              <% if(order.user_email) { %>
                <p class="text-gray-500 text-xs"><%= order.user_email %></p>
              <% } %>
            </div>
          </div>

          <!-- Shipping -->
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5">
            <h3 class="font-black text-gray-900 mb-4 flex items-center gap-2">
              <svg class="w-4 h-4 text-[#e09e2b]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
              Shipping
            </h3>
            <div class="space-y-1 text-sm font-medium text-gray-600">
              <p><%= order.shipping_address %></p>
              <p><%= order.shipping_city %>, <%= order.shipping_pincode %></p>
            </div>
          </div>

          <!-- Payment -->
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5">
            <h3 class="font-black text-gray-900 mb-4 flex items-center gap-2">
              <svg class="w-4 h-4 text-[#e09e2b]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
              Payment
            </h3>
            <div class="space-y-2 text-sm font-medium">
              <div class="flex justify-between">
                <span class="text-gray-500">Method</span>
                <span class="font-bold">UPI / QR</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">Ref #</span>
                <span class="font-mono font-bold text-xs"><%= order.payment_ref %></span>
              </div>
              <div class="flex justify-between font-black border-t pt-2 mt-2">
                <span>Total</span>
                <span class="text-[#e09e2b]">₹<%= order.total %></span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
