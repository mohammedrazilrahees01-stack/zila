<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard — Zila Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>* { font-family: 'Poppins', sans-serif; } .stat-card { transition: all 0.2s; } .stat-card:hover { transform: translateY(-2px); }</style>
  <% const currentPage = 'dashboard'; %>
</head>
<body class="bg-gray-100 min-h-screen flex">

  <%- include('partials/owner-sidebar') %>

  <!-- Main Content -->
  <div class="flex-1 md:ml-64">
    <div class="md:p-8 p-4 pt-20 md:pt-8">

      <!-- Page Header -->
      <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-10">
        <div>
          <h1 class="text-3xl font-black text-gray-900">Dashboard</h1>
          <p class="text-gray-500 font-medium text-sm mt-1">Good to see you! Here's what's happening.</p>
        </div>
        <div class="flex gap-3">
          <a href="/owner/products/add" class="inline-flex items-center gap-2 bg-[#f8bc45] text-black px-5 py-2.5 rounded-xl font-bold text-sm hover:bg-[#e09e2b] transition shadow-lg shadow-yellow-200">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Add Product
          </a>
        </div>
      </div>

      <!-- STAT CARDS -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-5 mb-10">
        <!-- Revenue -->
        <div class="stat-card bg-gradient-to-br from-[#f8bc45] to-[#e09e2b] text-black p-6 rounded-2xl shadow-lg shadow-yellow-200/50">
          <div class="flex justify-between items-start mb-4">
            <div class="w-10 h-10 bg-black/10 rounded-xl flex items-center justify-center">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <span class="text-[10px] font-black bg-black/10 px-2 py-1 rounded-full uppercase">Revenue</span>
          </div>
          <p class="text-3xl font-black">₹<%= stats.totalRevenue || 0 %></p>
          <p class="text-sm font-medium opacity-70 mt-1">Total earnings</p>
        </div>

        <!-- Orders -->
        <div class="stat-card bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
          <div class="flex justify-between items-start mb-4">
            <div class="w-10 h-10 bg-blue-50 rounded-xl flex items-center justify-center">
              <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
            </div>
            <span class="text-green-600 text-xs font-bold bg-green-50 px-2 py-1 rounded-full">+<%= stats.newOrders || 0 %> new</span>
          </div>
          <p class="text-3xl font-black text-gray-900"><%= stats.totalOrders || 0 %></p>
          <p class="text-sm font-medium text-gray-500 mt-1">Total orders</p>
        </div>

        <!-- Customers -->
        <div class="stat-card bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
          <div class="flex justify-between items-start mb-4">
            <div class="w-10 h-10 bg-purple-50 rounded-xl flex items-center justify-center">
              <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
          </div>
          <p class="text-3xl font-black text-gray-900"><%= stats.totalCustomers || 0 %></p>
          <p class="text-sm font-medium text-gray-500 mt-1">Customers</p>
        </div>

        <!-- Products -->
        <div class="stat-card bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
          <div class="flex justify-between items-start mb-4">
            <div class="w-10 h-10 bg-orange-50 rounded-xl flex items-center justify-center">
              <svg class="w-5 h-5 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
            </div>
          </div>
          <p class="text-3xl font-black text-gray-900"><%= stats.totalProducts || 0 %></p>
          <p class="text-sm font-medium text-gray-500 mt-1">Products</p>
        </div>
      </div>

      <!-- PENDING ORDERS & RECENT ORDERS -->
      <div class="grid lg:grid-cols-3 gap-6 mb-6">

        <!-- Pending Verification (Important) -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
          <div class="p-6 border-b border-gray-100 flex items-center justify-between">
            <h2 class="font-black text-gray-900 flex items-center gap-2">
              <span class="w-2 h-2 bg-yellow-400 rounded-full animate-pulse"></span>
              Needs Verification
            </h2>
            <a href="/owner/orders?status=Pending+Verification" class="text-xs font-bold text-[#e09e2b] hover:underline">View All</a>
          </div>
          <div class="divide-y divide-gray-50">
            <% if(pendingOrders && pendingOrders.length > 0) { %>
              <% pendingOrders.slice(0, 4).forEach(order => { %>
                <a href="/owner/orders/<%= order.id %>" class="flex items-center justify-between p-4 hover:bg-gray-50 transition group">
                  <div>
                    <p class="text-sm font-bold text-gray-900">#<%= order.id %> — ₹<%= order.total %></p>
                    <p class="text-[10px] text-gray-400 font-medium mt-0.5">Ref: <span class="font-mono"><%= order.payment_ref %></span></p>
                  </div>
                  <svg class="w-4 h-4 text-gray-300 group-hover:text-gray-700 group-hover:translate-x-0.5 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </a>
              <% }) %>
            <% } else { %>
              <div class="p-8 text-center">
                <span class="text-3xl block mb-2">✅</span>
                <p class="text-gray-400 text-sm font-medium">All clear! No pending verifications.</p>
              </div>
            <% } %>
          </div>
        </div>

        <!-- Recent Orders (2/3 width) -->
        <div class="lg:col-span-2 bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
          <div class="p-6 border-b border-gray-100 flex items-center justify-between">
            <h2 class="font-black text-gray-900">Recent Orders</h2>
            <a href="/owner/orders" class="text-xs font-bold text-[#e09e2b] hover:underline">View All →</a>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead class="bg-gray-50 border-b border-gray-100">
                <tr>
                  <th class="text-left text-[10px] font-black text-gray-400 uppercase tracking-widest px-4 py-3">Order</th>
                  <th class="text-left text-[10px] font-black text-gray-400 uppercase tracking-widest px-4 py-3">Customer</th>
                  <th class="text-left text-[10px] font-black text-gray-400 uppercase tracking-widest px-4 py-3">Amount</th>
                  <th class="text-left text-[10px] font-black text-gray-400 uppercase tracking-widest px-4 py-3">Status</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-50">
                <% if(recentOrders && recentOrders.length > 0) { %>
                  <% recentOrders.slice(0, 6).forEach(order => { %>
                    <% const statusColors = {
                      'Pending Verification': 'bg-yellow-100 text-yellow-700',
                      'Approved': 'bg-blue-100 text-blue-700',
                      'Shipped': 'bg-purple-100 text-purple-700',
                      'Delivered': 'bg-green-100 text-green-700',
                      'Cancelled': 'bg-red-100 text-red-600'
                    }; %>
                    <tr class="hover:bg-gray-50 transition group">
                      <td class="px-4 py-4">
                        <a href="/owner/orders/<%= order.id %>" class="font-mono font-bold text-gray-900 text-sm hover:text-[#e09e2b] transition">#<%= order.id %></a>
                      </td>
                      <td class="px-4 py-4">
                        <p class="font-bold text-gray-900 text-sm"><%= order.shipping_name %></p>
                        <p class="text-[10px] text-gray-400"><%= new Date(order.created_at).toLocaleDateString('en-IN') %></p>
                      </td>
                      <td class="px-4 py-4 font-black text-gray-900 text-sm">₹<%= order.total %></td>
                      <td class="px-4 py-4">
                        <span class="text-[10px] font-bold px-2 py-1 rounded-full <%= statusColors[order.status] || 'bg-gray-100 text-gray-600' %>">
                          <%= order.status %>
                        </span>
                      </td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr><td colspan="4" class="text-center py-10 text-gray-400 text-sm">No orders yet.</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Bottom Row: Low Stock + Top Products -->
      <div class="grid md:grid-cols-2 gap-6">

        <!-- Low Stock Alert -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100">
          <div class="p-6 border-b border-gray-100 flex items-center justify-between">
            <h2 class="font-black text-gray-900 flex items-center gap-2">
              <span class="text-red-500">⚠️</span> Low Stock
            </h2>
            <a href="/owner/products" class="text-xs font-bold text-[#e09e2b]">Manage →</a>
          </div>
          <div class="p-4 space-y-3">
            <% if(lowStockProducts && lowStockProducts.length > 0) { %>
              <% lowStockProducts.forEach(p => { %>
                <div class="flex items-center justify-between p-3 bg-red-50/50 rounded-xl border border-red-100">
                  <div class="flex items-center gap-3">
                    <img src="/images/<%= p.image %>" class="w-8 h-10 object-cover rounded-lg">
                    <div>
                      <p class="text-sm font-bold text-gray-900 truncate max-w-[140px]"><%= p.name %></p>
                      <p class="text-[10px] text-gray-400"><%= p.category %></p>
                    </div>
                  </div>
                  <span class="text-red-600 font-black text-sm bg-red-100 px-2 py-1 rounded-lg"><%= p.stock %> left</span>
                </div>
              <% }) %>
            <% } else { %>
              <div class="py-8 text-center text-gray-400 text-sm">All products are well-stocked ✅</div>
            <% } %>
          </div>
        </div>

        <!-- Quick Stats -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100">
          <div class="p-6 border-b border-gray-100">
            <h2 class="font-black text-gray-900">Order Breakdown</h2>
          </div>
          <div class="p-6 space-y-4">
            <% [
              {label:'Pending Verification', count: stats.pendingCount || 0, color:'bg-yellow-400', text:'text-yellow-700'},
              {label:'Approved', count: stats.approvedCount || 0, color:'bg-blue-400', text:'text-blue-700'},
              {label:'Shipped', count: stats.shippedCount || 0, color:'bg-purple-400', text:'text-purple-700'},
              {label:'Delivered', count: stats.deliveredCount || 0, color:'bg-green-400', text:'text-green-700'},
              {label:'Cancelled', count: stats.cancelledCount || 0, color:'bg-red-400', text:'text-red-700'}
            ].forEach(s => { %>
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <div class="w-3 h-3 <%= s.color %> rounded-full flex-shrink-0"></div>
                  <span class="text-sm font-medium text-gray-700"><%= s.label %></span>
                </div>
                <div class="flex items-center gap-3">
                  <div class="h-2 bg-gray-100 rounded-full w-20 overflow-hidden">
                    <div class="h-full <%= s.color %> rounded-full" style="width:<%= stats.totalOrders > 0 ? Math.round(s.count / stats.totalOrders * 100) : 0 %>%"></div>
                  </div>
                  <span class="text-sm font-black text-gray-900 w-6 text-right"><%= s.count %></span>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      </div>

    </div>
  </div>
</body>
</html>
